{
  "version": 2,
  "framework": "nextjs",
  "functions": {
    "app/api/match/route.ts": {
      "maxDuration": 150
    },
    "app/api/cron/analyze-queue/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/drain/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/refresh-scores/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/label-intelligence/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/ping-worker",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/analyze-queue",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/refresh-scores",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/label-intelligence",
      "schedule": "0 4 * * *"
    }
  ]
}
