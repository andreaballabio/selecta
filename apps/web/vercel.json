{
  "version": 2,
  "framework": "nextjs",
  "functions": {
    "app/api/match/route.ts": {
      "maxDuration": 150
    },
    "app/api/cron/analyze-queue/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/drain/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/ping-worker",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/analyze-queue",
      "schedule": "*/2 * * * *"
    }
  ]
}
